{
  "name": "pixi-panel",
  "description": "Browser agnostic DevTools for PixiJS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm:dev:*\"",
    "dev:connect": "esbuild --bundle src/ui-connect/ui-connect.ts --watch --outfile=./build/ui-connect.txt",
    "dev:legacy": "esbuild --bundle src/pixi-devtools/ui-legacy.ts --watch --outfile=./build/ui-legacy.txt",
    "prebuild": "esbuild --bundle src/ui-connect/ui-connect.ts --outfile=./build/ui-connect.txt && esbuild --bundle src/pixi-devtools/ui-legacy.ts --outfile=./build/ui-legacy.txt"
  },
  "devDependencies": {
    "blender-elements": "workspace:*",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "phaser": "^4.1.0",
    "pixi.js": "^8.19.0",
    "ui-protocol": "workspace:*"
  }
}
