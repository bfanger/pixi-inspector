{
  "name": "pixi-devtools-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "build": "pnpm --parallel build",
    "test": "pnpm --parallel test",
    "lint": "concurrently -c \"#c596c7\",\"#4b32c3\",\"#676778\",\"#fafafa\" --kill-others-on-fail \"npm:lint:*\"",
    "lint:prettier": "prettier --check --log-level=warn .",
    "lint:eslint": "eslint --max-warnings=0 .",
    "lint:svelte-check": "svelte-check --fail-on-warnings",
    "lint:stylelint": "stylelint --max-warnings=0 \"packages/*/src/**/*.{css,svelte}\"",
    "format": "eslint --fix . && stylelint --fix \"packages/*/src/**/*.{css,svelte}\" && prettier --write --log-level=warn .",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "husky || true"
  },
  "lint-staged": {
    "*.(ts|tsx|svelte)": [
      "eslint --max-warnings 0 --no-ignore",
      "svelte-check --fail-on-warnings"
    ],
    "*.(js|cjs|mjs|jsx)": [
      "eslint --max-warnings 0 --no-ignore"
    ],
    "*.(json|css|md)": [
      "prettier --check --loglevel=warn"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/chrome": "^0.1.40",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260409.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "stylelint": "^17.6.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
